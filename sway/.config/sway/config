# ~/.config/sway/config

# Read `man 5 sway` for a complete reference.

# BEGIN_GLOBAL_VARIABLES 
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term 'kitty' 'zsh'
set $menu fuzzel

# BEGIN_SOUND_STACK
exec pipewire
exec pipewire-pulse
exec wireplumber
# END_SOUND_STACK

# AUTO_ROTATE
exec rot8 --touchscreen "Wacom HID 511A Finger" --stylus "Wacom HID 511A Pen"

# DEPENDENCIES
include ~/.config/sway/config.d/*

exec kitty

