# ~/.config/sway/config

# Read `man 5 sway` for a complete reference.

# BEGIN_GLOBAL_VARIABLES 
set $mod Mod4	# WinKey, Mod1=Alt
set $left h
set $down j
set $up k
set $right l
set $term 'kitty'
set $menu fuzzel

# BEGIN_SOUND_STACK
exec pipewire
exec pipewire-pulse
exec wireplumber
# END_SOUND_STACK

# DEPENDENCIES
include ~/.config/sway/config.d/*

exec kitty

