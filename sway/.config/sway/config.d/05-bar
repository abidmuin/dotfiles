# ~/.config/sway/config.d/05-bar

bar {
    position top
    font pango:JetBrainsMono Nerd Font 10
    
    status_command ~/.config/sway/swaybar-status.sh

    colors {
        statusline $gray
        background $bg
        
        # Format:            border  bg      text
        focused_workspace    $blue   $blue   $bg
        active_workspace     $gray   $bg     $blue
        inactive_workspace   $bg     $bg     $gray
        urgent_workspace     $red    $red    $bg
    }
}
