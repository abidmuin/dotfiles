# ~/.config/sway/config.d/01-inputs

# Read `man 5 sway-input` for more information about this section.

seat * xcursor_theme Adwaita 24

input type:touchpad {
	dwt enabled
	tap enabled
	natural_scroll enabled
	middle_emulation enabled
}

input type:touch {
	map_to_output *
	tap enabled
}

input type:tablet_tool {
	map_to_output *
}

